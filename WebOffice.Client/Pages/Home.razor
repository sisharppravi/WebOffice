@page "/"
@using WebOffice.Client.Services
@using Microsoft.AspNetCore.Components.Forms
@inject AuthService AuthSvc
@inject DocumentService DocSvc
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<PageTitle>Register / Login</PageTitle>

<div style="display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100vh;">
    @if (!string.IsNullOrEmpty(_currentUser))
    {
        <div class="text-center">
            <h3>Welcome, @_currentUser</h3>
            <p>You are logged in.</p>
            <button class="btn btn-outline-danger mb-3" @onclick="Logout">Logout</button>

            <div style="width: 480px; text-align:left;">
                <h5>Your documents</h5>

                <div class="mb-3">
                    <InputFile OnChange="OnInputFileChange" />
                    <button class="btn btn-sm btn-secondary ms-2" @onclick="LoadFiles">Refresh</button>
                    <button class="btn btn-sm btn-success ms-2" @onclick="CreateDocument">Create Document</button>
                </div>

                @if (_loadingFiles)
                {
                    <div>Loading...</div>
                }
                else if (_files != null && _files.Count > 0)
                {
                    <ul class="list-group">
                        @foreach (var f in _files)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <div>@f</div>
                                <div>
                                    <button class="btn btn-sm btn-outline-primary me-2" @onclick="() => EditFile(f)">Edit</button>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteFile(f)">Delete</button>
                                </div>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <div>No documents found.</div>
                }

                @if (!string.IsNullOrEmpty(_docMessage))
                {
                    <div class="mt-2 alert alert-info">@_docMessage</div>
                }
            </div>
        </div>
    }
    else
    {
        <h3 class="mb-3">@(_showLogin ? "Login" : "Register")</h3>

        <div class="mb-3 text-center">
            <button class="btn btn-outline-secondary me-2" @onclick="() => ToggleMode(false)" disabled="@(!_showLogin)">Register</button>
            <button class="btn btn-outline-secondary" @onclick="() => ToggleMode(true)" disabled="@(_showLogin)">Login</button>
        </div>

        <div style="display: flex; justify-content: center; align-items: center; flex-direction: column; width: 320px;">
            @if (!_showLogin)
            {
                <EditForm Model="_registerModel" OnValidSubmit="HandleRegisterSubmit">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="mb-3">
                        <label class="form-label">Login</label>
                        <InputText class="form-control" @bind-Value="_registerModel.Login" />
                        <ValidationMessage For="() => _registerModel.Login" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <InputText type="password" class="form-control" @bind-Value="_registerModel.Password" />
                        <ValidationMessage For="() => _registerModel.Password" />
                    </div>

                    <button type="submit" class="btn btn-primary">Register</button>
                </EditForm>
            }
            else
            {
                <EditForm Model="_loginModel" OnValidSubmit="HandleLoginSubmit">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="mb-3">
                        <label class="form-label">Login</label>
                        <InputText class="form-control" @bind-Value="_loginModel.Login" />
                        <ValidationMessage For="() => _loginModel.Login" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <InputText type="password" class="form-control" @bind-Value="_loginModel.Password" />
                        <ValidationMessage For="() => _loginModel.Password" />
                    </div>

                    <button type="submit" class="btn btn-primary">Login</button>
                </EditForm>
            }

            @* Отображаем HTTP код и тело ответа для отладки *@
            @if (_statusCode != null || !string.IsNullOrEmpty(_responseBody))
            {
                <div class="mt-3 w-100">
                    <div><strong>HTTP status:</strong> @_statusCode</div>
                    <div class="mt-2"><strong>Response body:</strong></div>
                    <pre style="white-space: pre-wrap; background:#f8f9fa; padding:10px; border-radius:4px;">@(_responseBody ?? "")</pre>
                </div>
            }

            @if (!string.IsNullOrEmpty(_successMessage))
            {
                <div class="alert alert-success mt-2">@_successMessage</div>
            }

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="alert alert-danger mt-2">@_errorMessage</div>
            }
        </div>
    }
</div>

@code {
    private RegisterModel _registerModel = new();
    private LoginModel _loginModel = new();
    private string? _successMessage;
    private string? _errorMessage;
    private int? _statusCode;
    private string? _responseBody;
    private string? _token;
    private bool _showLogin;
    private string? _currentUser;

    // new: documents
    private List<string>? _files;
    private bool _loadingFiles = false;
    private string? _docMessage;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _currentUser = await AuthSvc.GetCurrentUserAsync();
            if (!string.IsNullOrEmpty(_currentUser))
            {
                await LoadFiles();
            }
            StateHasChanged();
        }
    }

    private async Task LoadFiles()
    {
        _loadingFiles = true;
        _docMessage = null;
        try
        {
            var (status, body, files) = await DocSvc.GetUserFilesAsync();
            if (status >= 200 && status < 300)
            {
                _files = files ?? new List<string>();
            }
            else
            {
                _docMessage = $"Error loading files (HTTP {status}): {body}";
            }
        }
        catch (Exception ex)
        {
            _docMessage = ex.Message;
        }
        _loadingFiles = false;
        StateHasChanged();
    }

    private void ToggleMode(bool toLogin)
    {
        _showLogin = toLogin;
        ClearMessages();
    }

    private async Task HandleRegisterSubmit()
    {
        ClearMessages();
        try
        {
            var (status, body) = await AuthSvc.RegisterAsync(new AuthService.RegisterModel { Login = _registerModel.Login, Password = _registerModel.Password });
            _statusCode = status;
            _responseBody = body;
            if (status >= 200 && status < 300)
            {
                _successMessage = "Registration successful. You can now login.";
                _registerModel = new RegisterModel();
            }
            else
            {
                _errorMessage = $"Registration failed (HTTP {_statusCode}).";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private async Task HandleLoginSubmit()
    {
        ClearMessages();
        try
        {
            var (status, body, token) = await AuthSvc.LoginAsync(new AuthService.LoginModel { Login = _loginModel.Login, Password = _loginModel.Password });
            _statusCode = status;
            _responseBody = body;

            if (status >= 200 && status < 300)
            {
                _token = token;
                _currentUser = _loginModel.Login;
                _successMessage = "Login successful.";
                _loginModel = new LoginModel();
                await LoadFiles();
            }
            else
            {
                _errorMessage = $"Login failed (HTTP {_statusCode}).";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private async Task Logout()
    {
        await AuthSvc.LogoutAsync();
        _currentUser = null;
        _files = null;
        ClearMessages();
        StateHasChanged();
    }

    private void ClearMessages()
    {
        _successMessage = null;
        _errorMessage = null;
        _statusCode = null;
        _responseBody = null;
        _token = null;
        _docMessage = null;
    }

    private async Task OnFileSelected(ChangeEventArgs e)
    {
        // removed - replaced by InputFile handler
        await Task.CompletedTask;
    }

    private async Task OnInputFileChange(InputFileChangeEventArgs e)
    {
        _docMessage = null;
        try
        {
            var current = await AuthSvc.GetCurrentUserAsync();
            if (string.IsNullOrEmpty(current))
            {
                _docMessage = "You are not logged in. Please login before uploading files.";
                return;
            }

            var file = e.File;
            // Ограничение размера (например 50 MB)
            const long maxFileSize = 50 * 1024 * 1024;
            using var stream = file.OpenReadStream(maxFileSize);
            var (status, body) = await DocSvc.UploadFileAsync(stream, file.Name, file.ContentType ?? "application/octet-stream", file.Size);
            if (status >= 200 && status < 300)
            {
                _docMessage = "Upload successful.";
                await LoadFiles();
            }
            else
            {
                _docMessage = $"Upload failed (HTTP {status}): {body}";
            }
        }
        catch (Exception ex)
        {
            _docMessage = ex.Message;
        }
    }

    private async Task DeleteFile(string fileName)
    {
        _docMessage = null;
        try
        {
            var (status, body) = await DocSvc.DeleteFileAsync(fileName);
            if (status >= 200 && status < 300)
            {
                _docMessage = "Deleted";
                await LoadFiles();
            }
            else
            {
                _docMessage = $"Delete failed (HTTP {status}): {body}";
            }
        }
        catch (Exception ex)
        {
            _docMessage = ex.Message;
        }
    }

    private async Task EditFile(string fileName)
    {
        // For now: attempt to download and open in new tab as blob
        try
        {
            var user = await AuthSvc.GetCurrentUserAsync();
            var apiBase = "http://localhost:7130"; // adjust if needed
            var url = $"{apiBase}/onlyoffice/edit?fileName={Uri.EscapeDataString(fileName)}" + (string.IsNullOrEmpty(user) ? string.Empty : $"&userId={Uri.EscapeDataString(user)}");
            await JS.InvokeVoidAsync("open", url, "_blank");
        }
        catch (Exception ex)
        {
            _docMessage = ex.Message;
        }
    }

    private async Task CreateDocument()
    {
        try
        {
            var user = await AuthSvc.GetCurrentUserAsync();
            var apiBase = "http://localhost:7130";
            var url = $"{apiBase}/onlyoffice/create" + (string.IsNullOrEmpty(user) ? string.Empty : $"?userId={Uri.EscapeDataString(user)}");
            await JS.InvokeVoidAsync("open", url, "_blank");
        }
        catch (Exception ex)
        {
            _docMessage = ex.Message;
        }
    }

    public class RegisterModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        public string Login { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.MinLength(6)]
        public string Password { get; set; } = string.Empty;
    }

    public class LoginModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        public string Login { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.MinLength(6)]
        public string Password { get; set; } = string.Empty;
    }
}
